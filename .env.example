# Root env for docker-compose. Copy to `.env` and adjust before `docker compose up`.

# Backend secrets
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OpenAI (optional — AI features fall back to canned responses when unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# URLs / CORS
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
